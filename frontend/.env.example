# Supabase — get these from your project's Settings → API page
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key-here

# Backend API URL (for local dev use http://localhost:3001, for prod use your Render URL)
VITE_API_URL=https://your-backend.onrender.com

# ── Server-side ONLY (set these in Vercel → Project → Settings → Environment
# Variables; they are read by the api/ serverless functions and are NEVER
# exposed to the browser — that's why they have NO VITE_ prefix).
#
# SUPABASE_URL              — same project URL as VITE_SUPABASE_URL above.
# SUPABASE_SERVICE_ROLE_KEY — Settings → API → service_role secret. Bypasses
#                             RLS: keep it server-side, never commit it, and
#                             never give it a VITE_ prefix.
#
# Used for zero-PII usage analytics (the usage_events table). If these are
# missing the app still works perfectly — analytics is silently disabled and
# /api/public/stats falls back to its static numbers.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-here
